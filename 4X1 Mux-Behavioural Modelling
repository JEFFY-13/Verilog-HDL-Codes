module mux2(d0, d1, d2, d3, s0, s1, y); 
  input d0, d1, d2, d3; 
  input s0, s1; 
  output y; 
  reg y; 
  always @(s1,s0) begin 
    if (s1 == 0 && s0 == 0) begin 
      y = d0; 
    end 
    else if (s1 == 0 && s0 == 1) begin 
      y = d1; 
    end 
    else if (s1 == 1 && s0 == 0) begin 
      y = d2; 
    end 
    else if (s1 == 1 && s0 == 1) begin 
      y = d3; 
    end 
  end 
endmodule 
